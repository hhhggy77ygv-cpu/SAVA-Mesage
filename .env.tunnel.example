# Cloudflare Tunnel Configuration Example
# Copy this to apps/server/.env and update with your tunnel URL

# После запуска туннеля (npm run tunnel:simple) вы получите URL
# Добавьте его сюда:
CORS_ORIGINS=http://localhost:5173,https://localhost:5174,https://your-tunnel-url.trycloudflare.com

# Пример:
# CORS_ORIGINS=http://localhost:5173,https://localhost:5174,https://random-words-1234.trycloudflare.com

# Другие настройки (опционально)
PORT=3001
JWT_SECRET=your-secret-will-be-auto-generated
ENCRYPTION_KEY=your-64-char-hex-key-for-message-encryption

# TURN/STUN серверы для WebRTC (опционально)
TURN_URL=turn:your-domain.com:3478
TURN_SECRET=your-turn-secret
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
