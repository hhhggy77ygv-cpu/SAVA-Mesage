{
  "name": "sava-messenger",
  "version": "1.0.0",
  "description": "SAVA Messenger - современный мессенджер",
  "main": "main.js",
  "bin": "main.js",
  "author": "SAVA Team",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,web -c \"#6366f1\",\"#8b5cf6\" \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "dev:admin": "concurrently -k -n server,admin \"npm run dev -w apps/server\" \"npm run dev -w apps/admin\"",
    "dev:all": "concurrently -k -n server,web,admin \"npm run dev -w apps/server\" \"npm run dev -w apps/web\" \"npm run dev -w apps/admin\"",
    "dev:desktop": "npm run start -w apps/desktop",
    "dev:tunnel": "concurrently -k -n server,web,tunnel -c \"#6366f1\",\"#8b5cf6\",\"#f59e0b\" \"npm run dev -w apps/server\" \"npm run dev -w apps/web\" \"npm run tunnel:start\"",
    "tunnel:setup": "powershell -ExecutionPolicy Bypass -File setup-tunnel.ps1",
    "tunnel:start": "powershell -ExecutionPolicy Bypass -File start-tunnel.ps1",
    "tunnel": "powershell -ExecutionPolicy Bypass -File start-tunnel.ps1",
    "tunnel:simple": "cloudflared tunnel --url https://localhost:3001",
    "tunnel:login": "cloudflared tunnel login",
    "tunnel:create": "cloudflared tunnel create sava-messenger",
    "tunnel:list": "cloudflared tunnel list",
    "tunnel:route": "cloudflared tunnel route dns sava-messenger",
    "tunnel:info": "cloudflared tunnel info sava-messenger",
    "tunnel:custom": "powershell -ExecutionPolicy Bypass -File start-custom-tunnel.ps1",
    "tunnel:custom-bat": "start-custom-tunnel.bat",
    "production": "start-production.bat",
    "build": "npm run build -w apps/server && npm run build -w apps/web",
    "build:desktop": "npm run build -w apps/web && npm install -w apps/desktop && npm run build:win -w apps/desktop",
    "build:desktop-installer": "powershell -ExecutionPolicy Bypass -File build-desktop-installer.ps1",
    "build:exe": "pkg . --targets node20-win-x64 --output dist/SAVA.exe",
    "db:push": "npm run db:push -w apps/server",
    "db:seed": "npm run db:seed -w apps/server",
    "setup": "npm install && npm run db:push && npm run db:seed",
    "start": "npm run dev"
  },
  "pkg": {
    "scripts": [
      "apps/server/dist/**/*.js",
      "apps/web/dist/assets/**/*",
      "apps/admin/dist/assets/**/*"
    ],
    "assets": [
      "apps/web/dist",
      "apps/admin/dist",
      "apps/server/prisma",
      "apps/server/app-settings.json",
      "certs"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "concurrently": "^9.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "pkg": "^5.8.1",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
